# =============================================================================
# Lakeland School Hub - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.
# =============================================================================

# --- Azure Cosmos DB ---
REACT_APP_COSMOS_ENDPOINT=https://YOUR-COSMOS-DB.documents.azure.com:443/
REACT_APP_COSMOS_KEY=YOUR_COSMOS_PRIMARY_KEY

# --- Microsoft Entra ID (MSAL) ---
REACT_APP_AZURE_CLIENT_ID=YOUR_ENTRA_APP_CLIENT_ID
REACT_APP_AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID

# --- Azure Key Vault ---
REACT_APP_KEYVAULT_URL=https://YOUR-VAULT-NAME.vault.azure.net
